    # Best generation: 287
    # Last generation: 300
    #    metrics/precision,       metrics/recall,      metrics/mAP_0.5, metrics/mAP_0.5:0.95,         val/box_loss,         val/obj_loss,         val/cls_loss
    #              0.54634,              0.55625,              0.58201,              0.33665,             0.056451,             0.042892,             0.013441
    
