## Link to this sectionПолный пример кода#
    
    
    import io
    
    import cv2
    from sixel import SixelWriter
    
    from ultralytics import YOLO
    
    # Load a model
    model = YOLO("yolo26n.pt")
    
    # Run inference on an image
    results = model.predict(source="ultralytics/assets/bus.jpg")
    
    # Plot inference results
    plot = results[0].plot()  # (3)!
    
    # Results image as bytes
    im_bytes = cv2.imencode(
        ".png",  # (1)!
        plot,
    )[1].tobytes()  # (2)!
    
    mem_file = io.BytesIO(im_bytes)
    w = SixelWriter()
    w.draw(mem_file)

  1. Можно использовать и другие расширения изображений.
  2. Нужен только объект, возвращаемый по индексу `1`.
  3. Ознакомься с [параметрами метода plot](/ru/modes/predict#plot-method-parameters), чтобы узнать о доступных аргументах.



