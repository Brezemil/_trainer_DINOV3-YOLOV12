        @staticmethod
        def nets():
            """Get the scale model in a single invertible mapping."""
            return nn.Sequential(nn.Linear(2, 64), nn.SiLU(), nn.Linear(64, 64), nn.SiLU(), nn.Linear(64, 2), nn.Tanh())
    
        @staticmethod
