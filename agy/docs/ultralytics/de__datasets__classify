    |   |-- airplane/
    |   |   |-- 10008_airplane.png
    |   |   |-- 10009_airplane.png
    |   |   |-- ...
    |   |
    |   |-- automobile/
    |   |   |-- 1000_automobile.png
    |   |   |-- 1001_automobile.png
    |   |   |-- ...
    |   |
    |   |-- bird/
    |   |   |-- 10014_bird.png
    |   |   |-- 10015_bird.png
    |   |   |-- ...
    |   |
    |   |-- ...
    |
    |-- test/
    |   |-- airplane/
    |   |   |-- 10_airplane.png
    |   |   |-- 11_airplane.png
    |   |   |-- ...
    |   |
    |   |-- automobile/
    |   |   |-- 100_automobile.png
    |   |   |-- 101_automobile.png
    |   |   |-- ...
    |   |
    |   |-- bird/
    |   |   |-- 1000_bird.png
    |   |   |-- 1001_bird.png
    |   |   |-- ...
    |   |
    |   |-- ...
    |
    |-- val/ (optional)
