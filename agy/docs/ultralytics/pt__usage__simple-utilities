                [48.552, 398.56, 245.35, 902.71],
                [669.47, 392.19, 809.72, 877.04],
                [221.52, 405.8, 344.98, 857.54],
                [0, 550.53, 63.01, 873.44],
                [0.0584, 254.46, 32.561, 324.87],
            ]
        ),
        format="xyxy",
    )
    
    boxes.areas()
    # >>> array([ 4.1104e+05,       99216,       68000,       55772,       20347,      2288.5])
    
    boxes.convert("xywh")
    print(boxes.bboxes)
