      17: motorcycle
      18: bicycle
    
    # Map source label IDs to train IDs; ignore_label is converted to 255.
    label_mapping:
      -1: ignore_label
      0: ignore_label
      1: ignore_label
      2: ignore_label
      3: ignore_label
      4: ignore_label
