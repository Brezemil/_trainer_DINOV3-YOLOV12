    @staticmethod
    def _refdir(gitdir: Path | None) -> Path | None:
        """Resolve directory containing refs, objects, and config."""
        p = gitdir / "commondir" if gitdir else None
        if s := GitRepo._read(p):
            d = Path(s)
            return (gitdir / d).resolve() if not d.is_absolute() else d
        return gitdir

  
  


