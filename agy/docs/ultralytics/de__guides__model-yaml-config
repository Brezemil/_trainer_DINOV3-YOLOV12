        - [0, 1, Index, [192, 4]] # P3 features
        - [0, 1, Index, [384, 6]] # P4 features
        - [0, 1, Index, [768, 8]] # P5 features
        - [[1, 2, 3], 1, Detect, [nc]] # Multi-scale detection

