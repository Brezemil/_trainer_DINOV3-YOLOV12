### Link to this sectionEinfaches Erkennungsmodell#
    
    
    # Simple YOLO detection model
    nc: 80
    scales:
        n: [0.33, 0.25, 1024]
    
    backbone:
        - [-1, 1, Conv, [64, 3, 2]] # 0-P1/2
        - [-1, 1, Conv, [128, 3, 2]] # 1-P2/4
        - [-1, 3, C2f, [128, True]] # 2
        - [-1, 1, Conv, [256, 3, 2]] # 3-P3/8
        - [-1, 6, C2f, [256, True]] # 4
        - [-1, 1, SPPF, [256, 5]] # 5
    
    head:
        - [-1, 1, Conv, [256, 3, 1]] # 6
        - [[6], 1, Detect, [nc]] # 7

