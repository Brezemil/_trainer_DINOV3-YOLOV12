{model_id}

Delete Model
    
    
    curl --request DELETE \
      --url https://api.example.com/v1/preview/models/{model_id} \
      --header 'Authorization: Bearer <token>'
    
    
    {
      "model_id": "3c90c3cc-0d44-4b50-8888-8dd25736052a",
      "deleted_checkpoints": 123,
      "deleted_run": true
    }

