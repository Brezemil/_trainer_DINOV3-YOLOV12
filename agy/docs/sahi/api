    def get_coco_segmentation_from_bool_mask(bool_mask: np.ndarray) -> list[list[float]]:
        """Convert boolean mask to COCO segmentation format.
    
        Converts a 2D boolean mask to COCO polygon format:
        [
            [x1, y1, x2, y2, x3, y3, ...],
            [x1, y1, x2, y2, x3, y3, ...],
            ...
        ].
